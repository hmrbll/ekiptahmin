# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (local PostgreSQL)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:YOUR_PG_PASSWORD@localhost:5432/ekiptahmin_dev

# Email (Resend) - leave blank for dev (uses console backend)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@ekiptahmin.com

# Site
SITE_URL=http://localhost:8000
